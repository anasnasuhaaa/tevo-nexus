generator client {
  provider            = "prisma-client"
  output              = "../src/generated/prisma"
  importFileExtension = "ts"
}

datasource db {
  provider = "postgresql"
  schemas  = ["core", "nexus", "tevo"]
}

enum UnitType {
  BPH
  BIRO
  DEPARTEMEN

  @@schema("core")
}

enum OrganizationalPosition {
  KETUA_ORGANISASI
  WAKIL_KETUA_ORGANISASI
  SEKRETARIS_INTERNAL
  SEKRETARIS_EKSTERNAL
  BENDAHARA_INTERNAL
  BENDAHARA_EKSTERNAL
  KETUA_BIRDEP
  SEKRETARIS_BIRDEP
  BENDAHARA_BIRDEP
  ANGGOTA_BIRDEP

  @@schema("core")
}

model CabinetPeriod {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isActive  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  birdeps     Birdep[]
  memberships Membership[]

  @@schema("core")
}

model Birdep {
  id              String   @id @default(uuid())
  cabinetPeriodId String
  name            String
  code            String
  slug            String
  unitType        UnitType
  description     String   @db.Text
  focusArea       String   @db.Text
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  cabinetPeriod CabinetPeriod @relation(fields: [cabinetPeriodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  memberships   Membership[]

  @@unique([cabinetPeriodId, code])
  @@unique([cabinetPeriodId, slug])
  @@schema("core")
}

model Member {
  id        String   @id @default(uuid())
  fullName  String
  nim       String   @unique
  instagram String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  users       User[]

  @@schema("core")
}

model Membership {
  id                     String                 @id @default(uuid())
  memberId               String
  cabinetPeriodId        String
  primaryBirdepId        String
  organizationalPosition OrganizationalPosition
  internalTitle          String?
  subdivision            String?
  programRoles           String?                @db.Text
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt

  member        Member        @relation(fields: [memberId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  cabinetPeriod CabinetPeriod @relation(fields: [cabinetPeriodId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  primaryBirdep Birdep        @relation(fields: [primaryBirdepId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@unique([memberId, cabinetPeriodId])
  @@index([cabinetPeriodId])
  @@index([primaryBirdepId])
  @@schema("core")
}

model User {
  id                 String    @id
  name               String
  email              String
  emailVerified      Boolean
  image              String?
  role               String    @default("ANGGOTA_BIRDEP")
  banned             Boolean   @default(false)
  banReason          String?
  banExpires         DateTime?
  mustChangePassword Boolean   @default(true)
  memberId           String?
  createdAt          DateTime
  updatedAt          DateTime

  member              Member?                  @relation(fields: [memberId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sessions            Session[]
  accounts            Account[]
  userRoles           UserRole[]
  permissionOverrides UserPermissionOverride[]

  @@unique([email])
  @@index([memberId])
  @@map("user")
  @@schema("nexus")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime
  updatedAt DateTime
  ipAddress String?
  userAgent String?
  userId    String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@map("session")
  @@schema("nexus")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
  @@schema("nexus")
}

model Verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?

  @@map("verification")
  @@schema("nexus")
}

model Role {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  isSystem    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@schema("nexus")
}

model Permission {
  id          String   @id @default(uuid())
  code        String   @unique
  name        String
  description String   @db.Text
  module      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions         RolePermission[]
  userPermissionOverrides UserPermissionOverride[]

  @@schema("nexus")
}

model UserRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@schema("nexus")
}

model RolePermission {
  id           String   @id @default(uuid())
  roleId       String
  permissionId String
  createdAt    DateTime @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@schema("nexus")
}

model UserPermissionOverride {
  id           String   @id @default(uuid())
  userId       String
  permissionId String
  allowed      Boolean
  reason       String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@index([permissionId])
  @@schema("nexus")
}
